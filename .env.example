##
# Cortex Lite — .env.example
# All variables across all phases. Values blank except pinned model IDs.
# Copy to .env, fill in secrets, never commit .env.
##

# --- App ---
APP_NAME="Cortex Lite"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

# --- Frontend (Vite dev server, host-run) ---
FRONTEND_URL=http://localhost:5173
VITE_APP_NAME="${APP_NAME}"
VITE_API_BASE_URL=http://localhost:8080

# --- Logging ---
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# --- Database (MySQL in docker-compose) ---
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=cortex_lite
DB_USERNAME=cortex
DB_PASSWORD=cortex

# --- Session / cache / queue (database-backed session, matches Sanctum SPA cookie auth) ---
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=localhost
SESSION_SAME_SITE=lax
SESSION_SECURE_COOKIE=false

CACHE_STORE=redis
QUEUE_CONNECTION=redis
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# --- Redis ---
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- Sanctum SPA auth (Phase 1) ---
# Comma-separated hosts (no scheme). Include the Vite dev origin.
SANCTUM_STATEFUL_DOMAINS=localhost:5173

# --- Mail ---
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@cortex-lite.example"
MAIL_FROM_NAME="${APP_NAME}"

# --- Steam Web API (Phase 2) ---
STEAM_API_KEY=
STEAM_OPENID_REALM=http://localhost:8080
STEAM_OPENID_RETURN_URL=http://localhost:8080/api/steam/callback

# --- PCGamingWiki (Phase 4) ---
# Required for the Cortex-Lite User-Agent sent to PCGamingWiki Cargo API requests.
PCGAMINGWIKI_CONTACT_EMAIL=
PCGAMINGWIKI_CACHE_STORE=redis

# --- Gemini API (Phase 5) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
GEMINI_CACHE_STORE=redis

# --- Stripe (Phase 5) ---
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
CASHIER_CURRENCY=myr
STRIPE_PRICE_PREMIUM=

# --- AWS (Phase 6) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-southeast-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false
SSM_PARAMETER_PATH=/cortex-lite/
ECR_REGISTRY=
